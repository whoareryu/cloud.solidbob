# --- Database (Neon PostgreSQL, 비동기 asyncpg 드라이버) ---
# Neon 대시보드 → 프로젝트 → Connect → Connection string 을 복사하되,
# 비동기 엔진(SQLAlchemy AsyncSession)을 위해 다음을 맞춘다:
#   - 드라이버: postgresql+asyncpg://  (psycopg/동기 아님)
#   - SSL 파라미터: ?ssl=require       (asyncpg는 sslmode 미지원 → ssl 사용)
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/neondb?ssl=require
# 참고: Neon 이 준 postgresql://...?sslmode=require 를 붙여도 core.database 가
#       자동으로 +asyncpg / ssl 로 변환하지만, 위 비동기 형식을 권장한다.

# 개발 환경에서 ORM 기반 테이블 자동 생성 (Alembic 미사용 시)
ENV=development
AUTO_CREATE_TABLES=1
# SQL_ECHO=1

# 앱 시작 시 목업 데이터 자동 시드 (멱등 — 여러 번 실행해도 안전)
AUTO_SEED=1

# --- Blockchain (medical_record 모듈, Hardhat 로컬 노드) ---
# Hardhat 노드 RPC 엔드포인트
HARDHAT_RPC_URL=http://127.0.0.1:8545
# 배포된 앵커 스마트 계약 주소 (비우면 인메모리 시뮬레이션으로 폴백)
ANCHOR_CONTRACT_ADDRESS=

# --- Redis (share_token 모듈, 일회성 공유 토큰) ---
# 비우거나 미연결 시 인메모리 폴백으로 동작
REDIS_URL=redis://127.0.0.1:6379/0
